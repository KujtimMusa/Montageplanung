# Kopieren nach .env.local und echte Werte eintragen (dieses File nur Platzhalter!)

# Supabase (Projekt-Einstellungen → API)
NEXT_PUBLIC_SUPABASE_URL=https://IHRE_PROJEKT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=IHRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=IHRE_SERVICE_ROLE_KEY

# Google Gemini (KI-Agenten)
GEMINI_API_KEY=IHRE_GEMINI_API_KEY

# Microsoft Graph (Phase 4 — optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# WhatsApp / Twilio (Phase 6 — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# E-Mail (Resend — optional)
RESEND_API_KEY=

# App-URL (Vercel Production URL oder lokal)
NEXT_PUBLIC_APP_URL=http://localhost:3000
